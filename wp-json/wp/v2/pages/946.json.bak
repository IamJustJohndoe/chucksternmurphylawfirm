    "rendered": "<div class=\"wpb-content-wrapper\"><p>[vc_row triangle_shape=&#8221;no&#8221;][vc_column][vc_raw_html][\/vc_raw_html][\/vc_column][\/vc_row][vc_row content_width=&#8221;grid&#8221; triangle_shape=&#8221;no&#8221; css=&#8221;.vc_custom_1447839811894{padding-top: 58px !important;padding-bottom: 23px !important;background-color: #f2f2f2 !important;}&#8221;][vc_column offset=&#8221;vc_col-lg-4 vc_col-md-4&#8243;][vc_column_text]<\/p>\n<h2>Our Offices<\/h2>\n<p>[\/vc_column_text]<div class=\"mkd-separator-holder clearfix  mkd-separator-center mkd-separator-full-width\" style=\"margin-top: -9px; margin-bottom: 0px; height: 0px\">\n\t<div class=\"mkd-separator\" style=\"border-color: rgba(255,255,255,0.01);border-bottom-width: 0px\"><\/div>\n<\/div>\n[vc_empty_space height=&#8221;20px&#8221;][vc_single_image image=&#8221;199&#8243; img_size=&#8221;full&#8221;][vc_empty_space height=&#8221;55px&#8221;][\/vc_column][vc_column offset=&#8221;vc_col-lg-4 vc_col-md-4&#8243;][vc_column_text]<\/p>\n<h2>Free Consultation<\/h2>\n<p>[\/vc_column_text]<div class=\"mkd-separator-holder clearfix  mkd-separator-center mkd-separator-full-width\" style=\"margin-top: -9px; margin-bottom: 0px; height: 0px\">\n\t<div class=\"mkd-separator\" style=\"border-color: rgba(255,255,255,0.01);border-bottom-width: 0px\"><\/div>\n<\/div>\n[vc_empty_space height=&#8221;20px&#8221;][vc_raw_html css=&#8221;&#8221;][\/vc_raw_html][vc_empty_space height=&#8221;55px&#8221;][\/vc_column][vc_column offset=&#8221;vc_col-lg-4 vc_col-md-4&#8243;][vc_column_text]<\/p>\n<h2>Contact Us Now<\/h2>\n<p>[\/vc_column_text]<div class=\"mkd-separator-holder clearfix  mkd-separator-center mkd-separator-full-width\" style=\"margin-top: -9px; margin-bottom: 0px; height: 0px\">\n\t<div class=\"mkd-separator\" style=\"border-color: rgba(255,255,255,0.01);border-bottom-width: 0px\"><\/div>\n<\/div>\n[vc_empty_space height=&#8221;14px&#8221;][vc_column_text]<span style=\"text-decoration: underline;\">FRESNO OFFIC